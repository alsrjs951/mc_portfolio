---
import { getCollection } from 'astro:content';
import BaseLayout from '../layouts/BaseLayout.astro';
import ProjectCard from '../components/ProjectCard.astro';

const projects = (await getCollection('projects')).sort((a, b) => a.data.order - b.data.order);
const realProjects = projects.filter((project) => !project.data.sample);
const conceptProjects = projects.filter((project) => project.data.sample);

const proofByProject: Record<string, string> = {
  'company-organization': '주요 자산 변동 기록 · 자동 테스트 125개',
  'butcher-instance': '실패 자동 롤백 · 운영 복구 도구 포함',
  'sage-gear': '자동 테스트 33개 · 외부 콘텐츠 연동 API',
};
---

<BaseLayout>
  <section class="hero">
    <div class="hero-grid-pattern" aria-hidden="true"></div>
    <div class="container hero-grid">
      <div class="hero-copy">
        <div class="eyebrow"><span></span> MINECRAFT SERVER DEVELOPMENT</div>
        <h1>상상한 서버를,<br /><em>플레이 가능한 시스템</em>으로.</h1>
        <p class="hero-description">
          마인크래프트 개발을 몰라도 괜찮습니다. “회사끼리 경쟁했으면 좋겠어요”처럼<br class="desktop-only" />
          원하는 재미를 말해 주시면, 필요한 기능과 운영 방법까지 이해하기 쉽게 설계합니다.
        </p>
        <div class="hero-actions">
          <a class="button button--primary" href="#real-work">실제 개발 사례 보기 <span aria-hidden="true">↓</span></a>
          <button class="button button--secondary" type="button" data-copy-discord>
            Discord로 아이디어 보내기 <span aria-hidden="true">↗</span>
          </button>
        </div>
        <p class="hero-reassurance"><span aria-hidden="true">✓</span> 아이디어가 구체적이지 않아도 상담할 수 있습니다.</p>
      </div>

      <aside class="idea-panel" aria-label="구현 가능한 서버 경험 예시">
        <div class="idea-panel__header">
          <span>어떤 서버를 만들고 싶나요?</span>
          <b>IDEA MAP</b>
        </div>
        <a href="/projects/company-organization/">
          <span class="idea-number">01</span>
          <div><small>친구들과 회사를 키우는 재미</small><strong>조직 · 경제 · 주간 경쟁</strong></div>
          <span aria-hidden="true">↗</span>
        </a>
        <a href="/projects/sage-gear/">
          <span class="idea-number">02</span>
          <div><small>내 장비가 오래 성장하는 재미</small><strong>각성 · 강화 · 귀속 · 복구</strong></div>
          <span aria-hidden="true">↗</span>
        </a>
        <a href="/projects/butcher-instance/">
          <span class="idea-number">03</span>
          <div><small>기다리지 않고 혼자 즐기는 공간</small><strong>개인 인스턴스 · 목표 · 보상</strong></div>
          <span aria-hidden="true">↗</span>
        </a>
        <div class="idea-panel__footer">
          <span class="status-dot" aria-hidden="true"></span>
          <p><b>설명은 쉬운 말로,</b> 구현은 운영을 고려한 코드로 진행합니다.</p>
        </div>
      </aside>
    </div>

    <div class="container trust-strip" aria-label="포트폴리오 핵심 신뢰 지표">
      <div><strong>3</strong><span>공개 가능한<br />실제 구현 사례</span></div>
      <div><strong>158</strong><span>사례에 명시된<br />자동 테스트</span></div>
      <div><strong>Java 21</strong><span>Paper 기반<br />플러그인 개발</span></div>
      <p>숫자를 부풀리지 않습니다.<br />확인 가능한 내용만 사례에 적습니다.</p>
    </div>
  </section>

  <section class="section work-section" id="real-work" aria-labelledby="real-work-title">
    <div class="container">
      <div class="section-heading">
        <div><span class="section-index">01</span><p class="section-kicker">REAL PROJECTS</p><h2 id="real-work-title">말보다 먼저 보여드리는<br />실제 구현 사례</h2></div>
        <div class="heading-note">
          <span class="verified-mark" aria-hidden="true">✓</span>
          <p><b>샘플이 아닌 실제 개발 내용입니다.</b><br />문제, 해결 방식, 운영 예외까지 프로젝트별로 공개했습니다.</p>
        </div>
      </div>
      <div class="featured-grid">
        {realProjects.map((project, index) => (
          <ProjectCard project={project} index={index} proof={proofByProject[project.id]} />
        ))}
      </div>
    </div>
  </section>

  <section class="section plain-language-section" id="services" aria-labelledby="plain-language-title">
    <div class="container language-grid">
      <div class="language-intro">
        <span class="section-index">02</span>
        <p class="section-kicker">NO TECH KNOWLEDGE NEEDED</p>
        <h2 id="plain-language-title">기술 이름보다<br />원하는 재미부터 묻습니다.</h2>
        <p>플러그인, Skript, 데이터베이스를 미리 공부할 필요는 없습니다. 서버에서 플레이어가 무엇을 하고, 운영자는 무엇을 편하게 관리하고 싶은지만 알려주세요.</p>
      </div>
      <div class="translation-list">
        <article>
          <span>“회사끼리 경쟁하고 싶어요.”</span>
          <div aria-hidden="true">→</div>
          <p><b>조직·경제 시스템</b>권한, 금고, 창고, 생산, 계약과 랭킹을 하나의 흐름으로 설계합니다.</p>
        </article>
        <article>
          <span>“장비에 애착이 생겼으면 해요.”</span>
          <div aria-hidden="true">→</div>
          <p><b>장비 성장 시스템</b>각성, 능력치, 강화, 손상과 복구까지 성장 경험을 연결합니다.</p>
        </article>
        <article>
          <span>“운영자가 매번 개입하지 않았으면 해요.”</span>
          <div aria-hidden="true">→</div>
          <p><b>자동화·운영 도구</b>권한, 기록, 오류 복구와 관리자 명령어까지 함께 준비합니다.</p>
        </article>
      </div>
    </div>
  </section>

  <section class="section trust-section" id="trust" aria-labelledby="trust-title">
    <div class="container">
      <div class="section-heading section-heading--light">
        <div><span class="section-index">03</span><p class="section-kicker">WHY EPA</p><h2 id="trust-title">맡긴 뒤가 불안하지 않도록<br />세 가지를 지킵니다.</h2></div>
        <p>“일단 만들어 보고 맞추기”보다<br />완료 기준을 먼저 합의합니다.</p>
      </div>
      <div class="trust-principles">
        <article><span>01</span><h3>쉬운 요구사항 문서</h3><p>개발 용어 대신 플레이 흐름과 운영 상황으로 정리합니다. 무엇을 만들고 무엇은 범위에서 제외하는지 시작 전에 확인합니다.</p><b>받게 되는 것</b><small>기능 목록 · 예외 상황 · 일정 · 견적</small></article>
        <article><span>02</span><h3>실패까지 고려한 테스트</h3><p>정상 동작만 확인하지 않습니다. 중복 클릭, 재접속, 강제 종료, 동시 사용처럼 실제 서버에서 생기는 상황을 검증합니다.</p><b>확인하는 것</b><small>정상 흐름 · 오류 흐름 · 복구 가능 여부</small></article>
        <article><span>03</span><h3>운영 가능한 인수인계</h3><p>파일만 전달하고 끝내지 않습니다. 설치 방법, 변경 가능한 설정, 사용법과 주의사항을 운영자가 이해할 수 있게 안내합니다.</p><b>받게 되는 것</b><small>설치 파일 · 설정 · 사용 안내 · 협의된 사후 지원</small></article>
      </div>
    </div>
  </section>

  <section class="section process-section" id="process" aria-labelledby="process-title">
    <div class="container process-grid">
      <div class="process-intro">
        <span class="section-index">04</span><p class="section-kicker">HOW WE WORK</p><h2 id="process-title">처음 문의부터<br />서버 적용까지</h2>
        <p>각 단계에서 결정할 것과 받을 결과를 명확히 공유합니다.</p>
        <button class="button button--dark" type="button" data-copy-discord>Discord ID 복사하기 <span>↗</span></button>
      </div>
      <ol class="process-list">
        <li><span>01</span><div><h3>아이디어 듣기</h3><p>원하는 플레이 경험, 서버 버전과 현재 준비 상태를 확인합니다.</p></div><small>무료 문의</small></li>
        <li><span>02</span><div><h3>범위와 견적 정리</h3><p>필요 기능, 예외 상황, 일정과 비용을 쉬운 문서로 맞춥니다.</p></div><small>개발 전 확정</small></li>
        <li><span>03</span><div><h3>개발과 중간 공유</h3><p>확정한 기준으로 구현하고, 중요한 진행 내용과 변경점을 공유합니다.</p></div><small>변경 이력 관리</small></li>
        <li><span>04</span><div><h3>실제 환경 테스트</h3><p>동시 사용, 재접속, 오류와 복구 상황까지 서버 운영 기준으로 확인합니다.</p></div><small>완료 기준 확인</small></li>
        <li><span>05</span><div><h3>전달과 적용 안내</h3><p>설치 파일과 설정, 사용 방법을 전달하고 적용 과정을 안내합니다.</p></div><small>운영자 인수인계</small></li>
      </ol>
    </div>
  </section>

  <section class="section examples-section" id="projects" aria-labelledby="examples-title">
    <div class="container">
      <div class="section-heading">
        <div><span class="section-index">05</span><p class="section-kicker">DESIGN EXAMPLES</p><h2 id="examples-title">이런 시스템도<br />설계할 수 있습니다.</h2></div>
        <p>아래 항목은 실제 납품 사례가 아닌 설계 예시입니다.<br />가능한 작업 범위를 판단하는 참고 자료로만 봐주세요.</p>
      </div>
      <div class="concept-grid">
        {conceptProjects.map((project, index) => <ProjectCard project={project} index={index} compact />)}
      </div>
    </div>
  </section>

  <section class="section faq-section" aria-labelledby="faq-title">
    <div class="container faq-grid">
      <div><span class="section-index">06</span><p class="section-kicker">FAQ</p><h2 id="faq-title">의뢰 전에<br />많이 묻는 질문</h2><p>아직 서버가 없어도, 기능이 정리되지 않아도 괜찮습니다.</p></div>
      <div class="faq-list">
        <details open><summary>마인크래프트 서버를 처음 열어보는데도 의뢰할 수 있나요?<span aria-hidden="true">＋</span></summary><p>네. 만들고 싶은 서버 분위기와 플레이 방식부터 이야기해 주세요. 필요한 서버 종류, 버전, 플러그인 방식은 상담 과정에서 이해하기 쉽게 설명하고 함께 결정합니다.</p></details>
        <details><summary>플러그인과 Skript 중 무엇을 선택해야 하나요?<span aria-hidden="true">＋</span></summary><p>직접 선택하지 않아도 됩니다. 빠른 적용이 중요한 작은 기능인지, 여러 시스템과 연결되고 오래 확장할 핵심 기능인지에 따라 적합한 방식을 제안합니다.</p></details>
        <details><summary>비용과 기간은 어떻게 정해지나요?<span aria-hidden="true">＋</span></summary><p>기능 수만이 아니라 데이터 저장, 외부 플러그인 연동, 오류 복구 범위, 지원 버전과 일정에 따라 달라집니다. 개발 전에 범위와 견적을 먼저 정리합니다.</p></details>
        <details><summary>완성 후 오류가 생기거나 사용법을 모르겠으면요?<span aria-hidden="true">＋</span></summary><p>전달 시 설치와 설정, 사용 방법을 안내합니다. 완료 후 오류 수정과 버전 대응은 프로젝트별로 지원 범위와 기간을 미리 협의해 진행합니다.</p></details>
      </div>
    </div>
  </section>

  <section class="contact-section" aria-labelledby="contact-title">
    <div class="contact-grid-bg" aria-hidden="true"></div>
    <div class="container contact-inner">
      <p class="section-kicker">START WITH AN IDEA</p>
      <h2 id="contact-title">어떤 서버인지 한 문장만<br />들려주세요.</h2>
      <p>“친구들과 오래 할 경제 서버를 만들고 싶어요” 정도면 충분합니다.<br />필요한 질문은 제가 이어가겠습니다.</p>
      <button class="button button--contact" type="button" data-copy-discord>
        <span class="discord-logo" aria-hidden="true">D</span><span><small>DISCORD ID</small>__epa__</span><b>복사하고 문의하기 ↗</b>
      </button>
      <small class="contact-note">버튼을 누르면 Discord ID가 복사됩니다.</small>
    </div>
  </section>
</BaseLayout>
