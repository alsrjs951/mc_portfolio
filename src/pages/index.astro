---
import { getCollection } from 'astro:content';
import BaseLayout from '../layouts/BaseLayout.astro';
import ProjectCard from '../components/ProjectCard.astro';

const projects = (await getCollection('projects')).sort((a, b) => a.data.order - b.data.order);
const realProjects = projects.filter((project) => !project.data.sample);
const conceptProjects = projects.filter((project) => project.data.sample);

---

<BaseLayout>
  <section class="hero">
    <div class="hero-grid-pattern" aria-hidden="true"></div>
    <div class="container hero-grid">
      <div class="hero-copy">
        <div class="eyebrow"><span></span> MINECRAFT SERVER DEVELOPMENT</div>
        <h1>요구한 기능을,<br /><em>운영 가능한 시스템</em>으로.</h1>
        <p class="hero-description">
          서버 환경과 필요한 기능, 플레이 흐름을 구체적으로 알려주세요.<br class="desktop-only" />
          합의한 요구사항을 정확히 구현하고, 더 나은 선택지가 있으면 근거와 함께 제안합니다.
        </p>
        <div class="hero-actions">
          <a class="button button--primary" href="#real-work">실제 구현 사례 확인 <span aria-hidden="true">↓</span></a>
          <button class="button button--secondary" type="button" data-copy-discord>
            개발 의뢰 · 견적 문의 <span aria-hidden="true">↗</span>
          </button>
        </div>
        <p class="hero-reassurance"><span aria-hidden="true">✓</span> 제안은 선택지로 드리며, 최종 방향은 의뢰인이 결정합니다.</p>
      </div>

      <aside class="request-panel" aria-label="개발 의뢰 전 준비 정보">
        <div class="request-panel__header">
          <span>문의 전에 준비할 내용</span>
          <b>REQUEST BRIEF</b>
        </div>
        <ol class="request-checklist">
          <li><span>01</span><div><small>서버 정보</small><strong>버전 · 구동 환경 · 기존 플러그인</strong></div></li>
          <li><span>02</span><div><small>기능 명세</small><strong>시작 조건 · 동작 흐름 · 결과와 보상</strong></div></li>
          <li><span>03</span><div><small>운영 조건</small><strong>권한 · 설정 · 기록 · 예외 처리</strong></div></li>
          <li><span>04</span><div><small>일정과 참고 자료</small><strong>희망 일정 · 예산 · 유사 기능 자료</strong></div></li>
        </ol>
        <div class="request-panel__footer">
          <span class="status-dot" aria-hidden="true"></span>
          <p><b>설명이 구체적일수록</b> 작업 범위와 견적을 정확하게 안내할 수 있습니다.</p>
        </div>
      </aside>
    </div>

    <div class="container trust-strip" aria-label="포트폴리오 핵심 신뢰 지표">
      <div><strong>{realProjects.length}</strong><span>현재 공개된<br />실제 구현 사례</span></div>
      <div><strong>158</strong><span>사례에 명시된<br />자동 테스트</span></div>
      <p><b>기술 버전은 실력의 수치로 내세우지 않습니다.</b><br />구현 내용과 검증 근거는 각 사례에서 직접 확인할 수 있습니다.</p>
    </div>
  </section>

  <section class="section work-section" id="real-work" aria-labelledby="real-work-title">
    <div class="container">
      <div class="section-heading">
        <div><span class="section-index">01</span><p class="section-kicker">REAL PROJECTS</p><h2 id="real-work-title">말보다 먼저 보여드리는<br />실제 구현 사례</h2></div>
        <div class="heading-note">
          <span class="verified-mark" aria-hidden="true">✓</span>
          <p><b>샘플이 아닌 실제 개발 내용입니다.</b><br />상세 페이지에서 문제, 구현 기준과 주요 기능을 확인할 수 있습니다.</p>
        </div>
      </div>
      <div class="featured-grid">
        {realProjects.map((project, index) => <ProjectCard project={project} index={index} />)}
      </div>
    </div>
  </section>

  <section class="section plain-language-section" id="services" aria-labelledby="requirements-title">
    <div class="container language-grid">
      <div class="language-intro">
        <span class="section-index">02</span>
        <p class="section-kicker">SPECIFICATION FIRST</p>
        <h2 id="requirements-title">정확한 요구사항이<br />좋은 결과를 만듭니다.</h2>
        <p>의뢰인이 설명한 기능을 임의로 바꾸지 않습니다. 요청 내용을 개발 가능한 기준으로 정리하고, 보완할 방향이 있다면 이유와 영향을 함께 제안합니다.</p>
      </div>
      <div class="translation-list responsibility-list">
        <article>
          <span><small>01 · 의뢰인</small>필요한 기능을 설명합니다.</span>
          <div aria-hidden="true">→</div>
          <p><b>요구사항 전달</b>서버 환경, 기능별 동작, 화면 흐름, 예외 상황과 참고 자료를 충분히 전달합니다.</p>
        </article>
        <article>
          <span><small>02 · EPA</small>검토하고 대안을 제안합니다.</span>
          <div aria-hidden="true">→</div>
          <p><b>기술 검토와 추천</b>누락·충돌 가능성을 확인하고, 더 적합한 방법이 있다면 근거와 차이를 설명합니다.</p>
        </article>
        <article>
          <span><small>03 · 의뢰인</small>최종 방향을 결정합니다.</span>
          <div aria-hidden="true">→</div>
          <p><b>범위 확정 후 개발</b>제안의 채택 여부와 우선순위를 의뢰인이 결정하면, 확정된 요구사항 그대로 개발합니다.</p>
        </article>
      </div>
    </div>
  </section>

  <section class="section trust-section" id="trust" aria-labelledby="trust-title">
    <div class="container">
      <div class="section-heading section-heading--light">
        <div><span class="section-index">03</span><p class="section-kicker">WHY EPA</p><h2 id="trust-title">맡긴 뒤가 불안하지 않도록<br />세 가지를 지킵니다.</h2></div>
        <p>“일단 만들어 보고 맞추기”보다<br />완료 기준을 먼저 합의합니다.</p>
      </div>
      <div class="trust-principles">
        <article><span>01</span><h3>명확한 요구사항 문서</h3><p>설명받은 내용을 기능 흐름, 데이터, 예외 상황과 제외 범위로 구체화합니다. 개발을 시작하기 전에 서로 같은 결과를 예상하는지 확인합니다.</p><b>먼저 확정하는 것</b><small>기능 목록 · 동작 기준 · 제외 범위 · 일정 · 견적</small></article>
        <article><span>02</span><h3>실패까지 고려한 테스트</h3><p>정상 동작만 확인하지 않습니다. 중복 클릭, 재접속, 강제 종료, 동시 사용처럼 실제 서버에서 생기는 상황을 검증합니다.</p><b>확인하는 것</b><small>정상 흐름 · 오류 흐름 · 복구 가능 여부</small></article>
        <article><span>03</span><h3>운영 가능한 인수인계</h3><p>파일만 전달하고 끝내지 않습니다. 설치 방법, 변경 가능한 설정, 사용법과 주의사항을 운영자가 이해할 수 있게 안내합니다.</p><b>받게 되는 것</b><small>설치 파일 · 설정 · 사용 안내 · 협의된 사후 지원</small></article>
      </div>
    </div>
  </section>

  <section class="section process-section" id="process" aria-labelledby="process-title">
    <div class="container process-grid">
      <div class="process-intro">
        <span class="section-index">04</span><p class="section-kicker">HOW WE WORK</p><h2 id="process-title">처음 문의부터<br />서버 적용까지</h2>
        <p>각 단계에서 결정할 것과 받을 결과를 명확히 공유합니다.</p>
        <button class="button button--dark" type="button" data-copy-discord>개발 의뢰 · 견적 문의 <span>↗</span></button>
      </div>
      <ol class="process-list">
        <li><span>01</span><div><h3>요구사항 확인</h3><p>서버 환경, 필요한 기능, 동작 흐름과 운영 조건을 전달받습니다.</p></div><small>의뢰 내용 접수</small></li>
        <li><span>02</span><div><h3>검토·제안과 견적</h3><p>누락과 충돌 가능성을 확인하고, 필요한 제안과 함께 범위·일정·비용을 안내합니다.</p></div><small>최종 범위 확정</small></li>
        <li><span>03</span><div><h3>개발과 중간 공유</h3><p>확정한 기준으로 구현하고, 중요한 진행 내용과 변경점을 공유합니다.</p></div><small>변경 이력 관리</small></li>
        <li><span>04</span><div><h3>실제 환경 테스트</h3><p>동시 사용, 재접속, 오류와 복구 상황까지 서버 운영 기준으로 확인합니다.</p></div><small>완료 기준 확인</small></li>
        <li><span>05</span><div><h3>전달과 적용 안내</h3><p>설치 파일과 설정, 사용 방법을 전달하고 적용 과정을 안내합니다.</p></div><small>운영자 인수인계</small></li>
      </ol>
    </div>
  </section>

  <section class="section examples-section" id="projects" aria-labelledby="examples-title">
    <div class="container">
      <div class="section-heading">
        <div><span class="section-index">05</span><p class="section-kicker">DESIGN EXAMPLES</p><h2 id="examples-title">이런 시스템도<br />설계할 수 있습니다.</h2></div>
        <p>아래 항목은 실제 납품 사례가 아닌 설계 예시입니다.<br />가능한 작업 범위를 판단하는 참고 자료로만 봐주세요.</p>
      </div>
      <div class="concept-grid">
        {conceptProjects.map((project, index) => <ProjectCard project={project} index={index} compact />)}
      </div>
    </div>
  </section>

  <section class="section faq-section" aria-labelledby="faq-title">
    <div class="container faq-grid">
      <div><span class="section-index">06</span><p class="section-kicker">FAQ</p><h2 id="faq-title">의뢰 전에<br />많이 묻는 질문</h2><p>범위와 견적을 정확히 확인할 수 있도록 필요한 정보를 안내합니다.</p></div>
      <div class="faq-list">
        <details open><summary>문의 전에 어떤 내용을 준비해야 하나요?<span aria-hidden="true">＋</span></summary><p>서버 버전과 구동 환경, 필요한 기능, 기능이 시작되는 조건부터 결과까지의 흐름, 권한과 설정 방식, 예외 상황, 희망 일정과 참고 자료를 정리해 주세요. 내용이 구체적일수록 정확한 범위와 견적을 안내할 수 있습니다.</p></details>
        <details><summary>플러그인과 Skript 중 무엇을 선택해야 하나요?<span aria-hidden="true">＋</span></summary><p>원하는 방식이 있다면 해당 조건을 기준으로 검토합니다. 정하지 않았다면 기능 규모, 성능, 확장성과 유지보수 기준으로 차이를 설명하고 적합한 방향을 추천합니다. 최종 선택은 의뢰인이 결정합니다.</p></details>
        <details><summary>비용과 기간은 어떻게 정해지나요?<span aria-hidden="true">＋</span></summary><p>기능 수만이 아니라 데이터 저장, 외부 플러그인 연동, 오류 복구 범위, 지원 버전과 일정에 따라 달라집니다. 개발 전에 범위와 견적을 먼저 정리합니다.</p></details>
        <details><summary>완성 후 오류가 생기거나 사용법을 모르겠으면요?<span aria-hidden="true">＋</span></summary><p>전달 시 설치와 설정, 사용 방법을 안내합니다. 완료 후 오류 수정과 버전 대응은 프로젝트별로 지원 범위와 기간을 미리 협의해 진행합니다.</p></details>
      </div>
    </div>
  </section>

  <section class="contact-section" aria-labelledby="contact-title">
    <div class="contact-grid-bg" aria-hidden="true"></div>
    <div class="container contact-inner">
      <p class="section-kicker">REQUEST A QUOTE</p>
      <h2 id="contact-title">개발할 기능을 구체적으로<br />정리해 보내주세요.</h2>
      <p>서버 환경, 필요한 동작과 결과, 예외 조건, 희망 일정을 확인한 뒤<br />개발 범위와 견적을 안내합니다.</p>
      <button class="button button--contact" type="button" data-copy-discord>
        <span class="discord-logo" aria-hidden="true">D</span><span><small>DISCORD ID</small>__epa__</span><b>개발 의뢰 · 견적 문의 ↗</b>
      </button>
      <small class="contact-note">버튼을 누르면 Discord ID가 복사됩니다.</small>
    </div>
  </section>
</BaseLayout>
