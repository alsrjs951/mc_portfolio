---
import '../styles/global.css';
import { discordInviteUrl } from '../data/siteConfig.mjs';

interface Props {
  title?: string;
  description?: string;
  canonicalPath?: string;
}

const {
  title = 'EPA Development — 요구한 기능을 운영 가능한 마인크래프트 시스템으로',
  description = '구체적인 요구사항을 바탕으로 Minecraft 플러그인과 Skript를 개발합니다. 기술 검토, 대안 제안, 테스트와 운영 인수인계까지 제공합니다.',
  canonicalPath = Astro.url.pathname,
} = Astro.props;
const site = Astro.site ?? new URL('https://epa-development.alsrjs951.workers.dev');
const canonical = new URL(canonicalPath, site);
const ogImage = new URL('/og-v3.png', site);
---

<!doctype html>
<html lang="ko">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width" />
    <meta name="generator" content={Astro.generator} />
    <meta name="description" content={description} />
    <meta name="theme-color" content="#101510" />
    <link rel="canonical" href={canonical} />
    <link rel="icon" href="/favicon.svg" type="image/svg+xml" />
    <meta property="og:type" content="website" />
    <meta property="og:locale" content="ko_KR" />
    <meta property="og:site_name" content="EPA Development" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonical} />
    <meta property="og:image" content={ogImage} />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImage} />
    <title>{title}</title>
  </head>
  <body>
    <a class="skip-link" href="#main">본문으로 건너뛰기</a>
    <header class="site-header" data-header>
      <div class="container header-inner">
        <a class="brand" href="/" aria-label="EPA Development 홈">
          <span class="brand-mark" aria-hidden="true">E</span>
          <span>EPA <b>Development</b></span>
        </a>
        <nav class="nav" aria-label="주요 메뉴">
          <a href="/#real-work">실제 사례</a>
          <a href="/#trust">작업 기준</a>
          <a href="/#process">진행 방식</a>
          <a
            class="discord-button discord-button--small"
            href={discordInviteUrl}
            target="_blank"
            rel="noopener noreferrer"
            aria-label="Discord 서버에서 개발 의뢰·견적 문의하기"
          >
            <span class="status-dot" aria-hidden="true"></span>
            의뢰 · 견적 문의
          </a>
        </nav>
      </div>
    </header>
    <main id="main"><slot /></main>
    <footer class="site-footer">
      <div class="container footer-inner">
        <div>
          <a class="brand" href="/" aria-label="EPA Development 홈">
            <span class="brand-mark" aria-hidden="true">E</span>
            <span>EPA <b>Development</b></span>
          </a>
          <p>요구한 기능을, 운영 가능한 시스템으로.</p>
        </div>
        <div class="footer-meta">
          <span>Discord 서버</span>
          <a class="footer-link" href={discordInviteUrl} target="_blank" rel="noopener noreferrer">서버 입장 ↗</a>
          <small>© {new Date().getFullYear()} EPA Development</small>
        </div>
      </div>
    </footer>
    <script is:inline>
      (() => {
        const header = document.querySelector('[data-header]');
        const updateHeader = () => header?.classList.toggle('is-scrolled', window.scrollY > 16);
        updateHeader();
        window.addEventListener('scroll', updateHeader, { passive: true });
      })();
    </script>
  </body>
</html>
