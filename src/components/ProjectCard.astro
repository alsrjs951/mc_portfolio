---
import type { CollectionEntry } from 'astro:content';

interface Props {
  project: CollectionEntry<'projects'>;
  index?: number;
  compact?: boolean;
}

const { project, index = 0, compact = false } = Astro.props;
const { data } = project;
const typeLabel = data.type === 'plugin' ? 'PLUGIN' : 'SKRIPT';
const number = String(index + 1).padStart(2, '0');
const isReal = data.implementationType === 'real';
---

<article class:list={['project-card', { 'project-card--compact': compact, 'project-card--real': isReal }]} data-project-card data-type={data.type}>
  <a class="project-visual" href={`/projects/${project.id}/`} aria-label={`${data.title} 상세 보기`}>
    {data.thumbnail ? (
      <div class="project-thumbnail-wrap">
        <img class="project-thumbnail" src={data.thumbnail} alt={`${data.title} 대표 이미지`} width="1100" height="619" loading="lazy" decoding="async" />
        <span class="visual-number visual-number--thumbnail" aria-hidden="true">{number}</span>
      </div>
    ) : (
      <div class:list={['visual-grid', `visual-grid--${data.type}`]} aria-hidden="true">
        <span class="visual-number">{number}</span>
        <span class="code-line code-line--one"></span>
        <span class="code-line code-line--two"></span>
        <span class="code-line code-line--three"></span>
        <span class="visual-cube"></span>
      </div>
    )}
    <span class:list={['case-badge', { 'case-badge--sample': !isReal }]}>{isReal ? '실제 구현' : '설계 예시'}</span>
  </a>
  <div class="project-card__content">
    <div class="project-card__meta">
      <span>{typeLabel}</span>
      <span>{data.minecraftVersions.join(' · ')}</span>
    </div>
    <h3><a href={`/projects/${project.id}/`}>{data.title}</a></h3>
    <p class="project-summary">{data.summary}</p>
    {compact && <div class="tag-list">{data.stack.slice(0, 3).map((item) => <span>{item}</span>)}</div>}
    <a class="card-link" href={`/projects/${project.id}/`}>
      {isReal ? '상세 구현 사례 보기' : '설계 내용 보기'} <span aria-hidden="true">↗</span>
    </a>
  </div>
</article>
