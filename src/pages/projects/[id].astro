---
import { getCollection, render } from 'astro:content';
import { Image } from 'astro:assets';
import BaseLayout from '../../layouts/BaseLayout.astro';

export async function getStaticPaths() {
  const projects = await getCollection('projects');
  return projects.map((project) => ({ params: { id: project.id }, props: { project } }));
}

const { project } = Astro.props;
const { data } = project;
const { Content } = await render(project);
const typeLabel = data.type === 'plugin' ? 'PLUGIN' : 'SKRIPT';
---

<BaseLayout title={`${data.title} — EPA Development`} description={data.summary} canonicalPath={`/projects/${project.id}/`}>
  <article class="project-detail">
    <header class="project-hero">
      <div class="project-hero-grid" aria-hidden="true"></div>
      <div class="container">
        <a class="back-link" href={data.sample ? '/#projects' : '/#real-work'}>← {data.sample ? '설계 예시' : '실제 개발 사례'}</a>
        <div class="project-hero__meta">
          <span class:list={['type-badge', `type-badge--${data.type}`]}>{typeLabel}</span>
          <span class:list={['case-badge case-badge--detail', { 'case-badge--sample': data.sample }]}>{data.sample ? '설계 예시 · 실제 납품 사례 아님' : '실제 구현 사례'}</span>
        </div>
        <h1>{data.title}</h1>
        <p>{data.summary}</p>
        <div class="project-facts">
          <div><span>서버 환경</span><b>{data.serverType}</b></div>
          <div><span>지원 버전</span><b>{data.minecraftVersions.join(', ')}</b></div>
          <div><span>구현 기술</span><b>{data.stack.join(' · ')}</b></div>
        </div>
        {(data.sourceUrl || data.demoUrl) && (
          <div class="project-links">
            {data.demoUrl && <a href={data.demoUrl} target="_blank" rel="noreferrer">시연 보기 ↗</a>}
            {data.sourceUrl && <a href={data.sourceUrl} target="_blank" rel="noreferrer">공개 코드 보기 ↗</a>}
          </div>
        )}
      </div>
    </header>

    <div class="container project-layout">
      <div class="project-content">
        <section class="project-overview">
          <p class="section-kicker">01 · 한눈에 이해하기</p>
          <h2>이 시스템은 무엇을 해결했나요?</h2>
          <div class="overview-flow">
            <article><span>서버에서 겪던 문제</span><p>{data.problem}</p></article>
            <div aria-hidden="true">→</div>
            <article><span>구현한 해결 방식</span><p>{data.solution}</p></article>
          </div>
        </section>
        <section>
          <p class="section-kicker">02 · 플레이어와 운영자가 쓰는 기능</p>
          <h2>실제로 무엇을 할 수 있나요?</h2>
          <ul class="feature-checks">
            {data.features.map((feature) => <li><span aria-hidden="true">✓</span>{feature}</li>)}
          </ul>
        </section>
        {(data.screenshots.length > 0 || data.sample) && (
          <section>
            <p class="section-kicker">03 · 게임 화면</p>
            <h2>게임 화면</h2>
            <div class="screenshot-grid">
              {data.screenshots.length
                ? data.screenshots.map((screenshot) => (
                    <figure class="project-screenshot">
                      <Image src={screenshot.src} alt={screenshot.alt} widths={[480, 800, 1200]} sizes="(max-width: 760px) 100vw, 760px" loading="lazy" />
                    </figure>
                  ))
                : [1, 2, 3].map((number) => (
                    <div class="screenshot-placeholder">
                      <span>{String(number).padStart(2, '0')}</span>
                      <div aria-hidden="true"></div>
                      <p>실제 게임 스크린샷으로 교체</p>
                    </div>
                  ))}
            </div>
          </section>
        )}
        {data.code && (
          <section>
            <p class="section-kicker">04 · 구현 근거</p>
            <h2>선별 코드</h2>
            <div class="code-window">
              <div class="code-window__top"><span></span><span></span><span></span><b>{data.codeLanguage}</b></div>
              <pre><code>{data.code}</code></pre>
            </div>
            {data.decision && <div class="decision-note"><b>이렇게 판단한 이유</b><p>{data.decision}</p></div>}
          </section>
        )}
        <div class="project-markdown"><Content /></div>
      </div>
      <aside class="project-sidebar">
        <div class="sidebar-card">
          <p class="section-kicker">확인 정보</p>
          <dl>
            <div><dt>유형</dt><dd>{typeLabel}</dd></div>
            <div><dt>서버</dt><dd>{data.serverType}</dd></div>
            <div><dt>버전</dt><dd>{data.minecraftVersions.join(', ')}</dd></div>
            <div><dt>의존성</dt><dd>{data.dependencies.length ? data.dependencies.join(', ') : '없음'}</dd></div>
          </dl>
        </div>
        <div class="sidebar-contact">
          <span>비슷한 시스템의 개발이 필요하신가요?</span>
          <h2>요구사항과 서버 환경을<br />정리해 보내주세요.</h2>
          <button class="button button--primary" type="button" data-copy-discord>개발 의뢰 · 견적 문의 ↗</button>
        </div>
      </aside>
    </div>

    <nav class="project-next" aria-label="프로젝트 탐색">
      <div class="container">
        <p>다른 실제 개발 사례도 확인해 보세요.</p>
        <a href="/#real-work">실제 사례 전체 보기 <span aria-hidden="true">→</span></a>
      </div>
    </nav>
  </article>
</BaseLayout>
