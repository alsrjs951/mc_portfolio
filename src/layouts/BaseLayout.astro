---
import '../styles/global.css';

interface Props {
  title?: string;
  description?: string;
  canonicalPath?: string;
}

const {
  title = 'EPA Development — 상상한 마인크래프트 서버를 플레이 가능한 시스템으로',
  description = '마인크래프트 개발 지식이 없어도 괜찮습니다. 원하는 서버 경험을 듣고 플러그인 설계, 개발, 테스트와 운영 안내까지 함께합니다.',
  canonicalPath = Astro.url.pathname,
} = Astro.props;
const site = Astro.site ?? new URL('https://epa-development.alsrjs951.workers.dev');
const canonical = new URL(canonicalPath, site);
const ogImage = new URL('/og-v2.png', site);
---

<!doctype html>
<html lang="ko">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width" />
    <meta name="generator" content={Astro.generator} />
    <meta name="description" content={description} />
    <meta name="theme-color" content="#101510" />
    <link rel="canonical" href={canonical} />
    <link rel="icon" href="/favicon.svg" type="image/svg+xml" />
    <meta property="og:type" content="website" />
    <meta property="og:locale" content="ko_KR" />
    <meta property="og:site_name" content="EPA Development" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonical} />
    <meta property="og:image" content={ogImage} />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImage} />
    <title>{title}</title>
  </head>
  <body>
    <a class="skip-link" href="#main">본문으로 건너뛰기</a>
    <header class="site-header" data-header>
      <div class="container header-inner">
        <a class="brand" href="/" aria-label="EPA Development 홈">
          <span class="brand-mark" aria-hidden="true">E</span>
          <span>EPA <b>Development</b></span>
        </a>
        <nav class="nav" aria-label="주요 메뉴">
          <a href="/#real-work">실제 사례</a>
          <a href="/#trust">작업 기준</a>
          <a href="/#process">진행 방식</a>
          <button class="discord-button discord-button--small" type="button" data-copy-discord>
            <span class="status-dot" aria-hidden="true"></span>
            Discord 문의
          </button>
        </nav>
      </div>
    </header>
    <main id="main"><slot /></main>
    <footer class="site-footer">
      <div class="container footer-inner">
        <div>
          <a class="brand" href="/" aria-label="EPA Development 홈">
            <span class="brand-mark" aria-hidden="true">E</span>
            <span>EPA <b>Development</b></span>
          </a>
          <p>상상한 서버를, 플레이 가능한 시스템으로.</p>
        </div>
        <div class="footer-meta">
          <span>Discord</span>
          <button type="button" class="text-copy" data-copy-discord>__epa__ 복사</button>
          <small>© {new Date().getFullYear()} EPA Development</small>
        </div>
      </div>
    </footer>
    <div class="toast" role="status" aria-live="polite" aria-atomic="true" data-toast></div>
    <script is:inline>
      (() => {
        const discordId = '__epa__';
        const toast = document.querySelector('[data-toast]');
        let timer;

        const showToast = (message) => {
          if (!toast) return;
          toast.textContent = message;
          toast.classList.add('is-visible');
          window.clearTimeout(timer);
          timer = window.setTimeout(() => toast.classList.remove('is-visible'), 3600);
        };

        const fallbackCopy = () => {
          const input = document.createElement('input');
          input.value = discordId;
          input.setAttribute('readonly', '');
          input.style.position = 'fixed';
          input.style.opacity = '0';
          document.body.appendChild(input);
          input.select();
          const copied = Reflect.get(document, 'execCommand').call(document, 'copy');
          input.remove();
          return copied;
        };

        document.querySelectorAll('[data-copy-discord]').forEach((button) => {
          button.addEventListener('click', async () => {
            try {
              if (navigator.clipboard?.writeText) await navigator.clipboard.writeText(discordId);
              else if (!fallbackCopy()) throw new Error('copy failed');
              showToast('Discord ID __epa__를 복사했습니다. 친구 추가 후 문의해 주세요.');
            } catch {
              showToast('복사하지 못했습니다. Discord ID __epa__를 직접 복사해 주세요.');
              window.getSelection()?.selectAllChildren(button);
            }
          });
        });

        const header = document.querySelector('[data-header]');
        const updateHeader = () => header?.classList.toggle('is-scrolled', window.scrollY > 16);
        updateHeader();
        window.addEventListener('scroll', updateHeader, { passive: true });
      })();
    </script>
  </body>
</html>
