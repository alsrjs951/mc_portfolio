---
import { inquiryTemplate } from '../data/siteConfig.mjs';
---

<section class="section inquiry-section" id="inquiry-template" aria-labelledby="inquiry-template-title">
  <div class="container inquiry-grid">
    <div class="inquiry-intro">
      <span class="section-index">07</span>
      <p class="section-kicker">READY TO REQUEST</p>
      <h2 id="inquiry-template-title">한두 문장으로<br />편하게 시작하세요.</h2>
      <p>만들고 싶은 기능만 간단히 알려주셔도 됩니다. 버전, 예산이나 세부 동작을 아직 모르더라도 대화를 나누며 필요한 내용을 함께 정리합니다.</p>
      <div class="inquiry-reassurance"><span aria-hidden="true">✓</span><strong>양식은 선택 사항입니다.</strong> 자유롭게 문장으로 문의해도 괜찮습니다.</div>
      <button class="button button--dark" type="button" data-copy-inquiry>간단한 문의 양식 복사 <span aria-hidden="true">↗</span></button>
      <p class="copy-status" role="status" aria-live="polite" aria-atomic="true" data-copy-inquiry-status></p>
    </div>
    <div class="template-preview">
      <div class="template-preview__header"><span>필요할 때만 사용하는 간단 양식</span><b>OPTIONAL</b></div>
      <textarea readonly aria-label="복사할 문의 양식" data-inquiry-template>{inquiryTemplate}</textarea>
    </div>
  </div>
</section>

<script>
  import { copyText, createStatusController } from '../lib/copyText.mjs';

  const status = document.querySelector('[data-copy-inquiry-status]');
  const showStatus = status instanceof HTMLElement
    ? createStatusController({
        setMessage: (message) => { status.textContent = message; },
        setTimer: (callback, delay) => window.setTimeout(callback, delay),
        clearTimer: (timer) => window.clearTimeout(Number(timer)),
      })
    : null;

  document.querySelectorAll('[data-copy-inquiry]').forEach((button) => {
    button.addEventListener('click', async () => {
      const template = document.querySelector('[data-inquiry-template]');
      if (!(template instanceof HTMLTextAreaElement) || !showStatus) return;

      const copied = await copyText(template.value, { clipboard: navigator.clipboard, document });
      showStatus(copied
        ? '문의 양식을 복사했습니다'
        : '자동 복사에 실패했습니다. 오른쪽 양식을 직접 선택해 복사해 주세요.');
      if (!copied) {
        template.focus();
        template.select();
      }
    });
  });
</script>
